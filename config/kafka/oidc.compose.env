KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:29092,CONTROLLER://0.0.0.0:29093,PLAINTEXT_HOST://0.0.0.0:9092,OAUTH_HOST://0.0.0.0:9095,SSL_HOST://0.0.0.0:9093,SSL://0.0.0.0:29094
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://broker:29092,PLAINTEXT_HOST://localhost:9092,OAUTH_HOST://localhost:9095,SSL://broker:29094,SSL_HOST://localhost:9093
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT,OAUTH_HOST:SASL_PLAINTEXT,SSL:SSL,SSL_HOST:SSL
KAFKA_OPTS=-Djava.security.auth.login.config=/etc/kafka/secrets/kafka_oauth_server_jaas.conf
